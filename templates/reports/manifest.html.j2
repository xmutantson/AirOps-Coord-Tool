{# ------------------------------------------------------------------------
   Ramp Manifest — print-friendly HTML (A4/Letter)
   Context (examples):
     q: {
       id, tail_number, airfield_takeoff, airfield_landing, travel_time,
       cargo_type, remarks, direction,
       pilot_ack_name, pilot_ack_method, pilot_ack_signature_b64, pilot_ack_signed_at
     }
     items: [ {category_name, sanitized_name, wpu, qty, total}, ... ]
     generated_at_utc: ISO8601 string
   ------------------------------------------------------------------------ #}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Ramp Manifest — {{ mission_number or get_preference('mission_number') or 'Mission' }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {# Optional: use a scoped stylesheet if present #}
    {% if request and request.host %}
      <link rel="stylesheet" href="{{ url_for('static', filename='css/manifest.css') }}">
    {% endif %}
    <style>
      /* ---- Base (fallback if static/css/manifest.css not available) ---- */
      :root {
        --ink: #111;
        --muted: #666;
        --rule: #ddd;
        --soft: #f5f5f5;
      }
      html, body { height: 100%; }
      body {
        font: 12px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--ink);
        margin: 0;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page {
        padding: 18mm 16mm;
      }
      h1 { font-size: 18px; margin: 0 0 2mm 0; }
      h2 { font-size: 14px; margin: 0 0 2mm 0; }
      small, .muted { color: var(--muted); }
      .row { display: flex; gap: 10mm; align-items: flex-start; }
      .grow { flex: 1 1 auto; }
      .box {
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: 4mm;
        background: #fff;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 4mm;
        font-variant-numeric: tabular-nums;
      }
      th, td {
        border: 1px solid var(--rule);
        padding: 3.5mm;
        vertical-align: top;
      }
      thead th {
        background: #e8e8e8;
        text-align: left;
        font-weight: 700;
        color: #111;
      }
      .right { text-align: right; }
      .meta-table { border: 0; }
      .meta-table td { border: 0; padding: 1mm 0; }
      /* Keep a clean two-column look with clear separation */
      .meta-table td.label  { width: auto; white-space: nowrap; vertical-align: top; padding-right: 8mm; }
      .meta-table td.value  { width: auto; }
      .meta-table td.notes  {
        white-space: pre-wrap;
        word-break: break-word;
      }
      /* Add a visual colon after field labels so values never look jammed */
      .meta-table td.label > strong::after {
        content: ":";
        margin-left: .5ch;
      }
      .titleband {
        display:flex; justify-content: space-between; align-items: baseline;
        border-bottom: 2px solid var(--ink);
        margin-bottom: 3mm; padding-bottom: 2mm;
      }
      .badge {
        display: inline-block; border: 1px solid var(--rule); border-radius: 3px;
        padding: 1mm 2mm; background: #fff;
      }
      .sig {
        min-height: 20mm;
        display: flex; align-items: center; gap: 6mm;
      }
      .sig img { max-height: 18mm; }
      .footer {
        display: flex; justify-content: space-between; align-items: baseline;
        margin-top: 6mm; color: var(--muted);
      }
      /* Runway/Safety header (optional) */
      .safety {
        background: #fff7d6;
        border: 1px solid #e6d28d;
        padding: 2.5mm 3.5mm;
        border-radius: 4px;
        margin-bottom: 4mm;
        font-size: 11px;
      }
      @media print {
        @page { size: A4 portrait; margin: 12mm; }
        .page { padding: 0; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="titleband">
        <h1>Ramp Manifest <span class="badge">{{ (q.direction or 'Outbound')|title }}</span></h1>
        <div>
          <small>Mission Number:</small> <strong>{{ mission_number or get_preference('mission_number') or '—' }}</strong>
        </div>
      </div>

      <div class="safety">
        <strong>Runway &amp; Safety:</strong>
        Verify weight &amp; balance, secure cargo, confirm NOTAMs and field conditions, and adhere to local de-icing / FOD procedures.
      </div>

      <div class="row">
        <div class="grow box">
          <h2>Flight</h2>
          <table class="meta-table">
            <tr><td class="label"><strong>Tail</strong></td><td class="value">{{ q.tail_number }}</td></tr>
            <tr><td class="label"><strong>From</strong></td><td class="value">{{ q.airfield_takeoff }}</td></tr>
            <tr><td class="label"><strong>To</strong></td><td class="value">{{ q.airfield_landing }}</td></tr>
            <tr><td class="label"><strong>Travel Time</strong></td><td class="value">{{ q.travel_time }}</td></tr>
          </table>
        </div>
        <div class="grow box">
          <h2>Cargo</h2>
          <table class="meta-table">
            <tr><td class="label"><strong>Type</strong></td><td class="value">{{ q.cargo_type or '—' }}</td></tr>
            {% set _notes = (q.remarks or '').strip() %}
            {% if _notes and 'manifest:' not in _notes.lower() %}
            <tr><td class="label"><strong>Notes</strong></td><td class="value notes">{{ _notes }}</td></tr>
            {% endif %}
            {# If remarks is a Manifest: line, suppress entirely — tabular view shows the data #}
          </table>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th style="width:18%">Category</th>
            <th>Item</th>
            <th>Origin</th>
            <th class="right" style="width:10%">Unit (lb)</th>
            <th class="right" style="width:8%">Qty</th>
            <th class="right" style="width:12%">Total (lb)</th>
          </tr>
        </thead>
        <tbody>
          {# Prefer the backend-provided grand_total_weight; fall back to a namespace sum #}
          {% set ns = namespace(total=0.0) %}
          {% for it in items %}
            {% set ns.total = ns.total + (it.total | float(0)) %}
            <tr>
              <td>{{ it.category_name }}</td>
              <td>{{ it.sanitized_name }}</td>
              <td>{{ it.origin or '' }}</td>
              <td class="right">{{ it.wpu   | float(0) }}</td>
              <td class="right">{{ it.qty   | int(0) }}</td>
              <td class="right">{{ it.total | float(0) }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="6" class="muted">No itemized manifest rows.</td>
            </tr>
          {% endfor %}
        </tbody>
        <tfoot>
          <tr>
            <th colspan="5" class="right">Grand Total (lb)</th>
            <th class="right">
              {{ (grand_total_weight if grand_total_weight is defined else ns.total) | float }}
            </th>
          </tr>
        </tfoot>
      </table>

      <div class="box" style="margin-top: 6mm;">
        <h2>Pilot Acknowledgment</h2>
        <div class="sig">
          {% if q.pilot_ack_signature_b64 %}
            <img alt="Signature" src="{{ q.pilot_ack_signature_b64 }}">
          {% elif q.pilot_ack_name %}
            <strong>{{ q.pilot_ack_name }}</strong>
          {% else %}
            <span class="muted">— not yet acknowledged —</span>
          {% endif %}
          <div>
            <div><small>Method:</small> {{ q.pilot_ack_method or '—' }}</div>
            <div><small>Signed (UTC):</small> {{ q.pilot_ack_signed_at or '—' }}</div>
          </div>
        </div>
      </div>

      <div class="footer">
        <div><small>Generated (UTC):</small> {{ generated_at_utc or q.pilot_ack_signed_at or "" }}</div>
        <div><small>Print to: A4 or Letter, portrait</small></div>
      </div>
    </div>
  </body>
</html>
